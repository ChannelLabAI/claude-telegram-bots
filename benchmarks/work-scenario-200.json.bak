{
  "name": "MemOcean Work Scenario Benchmark v1",
  "version": "1.0",
  "created": "2026-04-11",
  "description": "200題中文工作場景搜尋品質評估基準",
  "corpus": "memory.db (473 closet + 5594 messages + KG)",
  "metrics": [
    "hit@1",
    "hit@3",
    "hit@5",
    "hit@10"
  ],
  "scenes": {
    "person_lookup": 20,
    "project_info": 25,
    "tech_architecture": 25,
    "decision_record": 20,
    "process_sop": 20,
    "product_feature": 20,
    "org_structure": 15,
    "temporal_reasoning": 15,
    "cross_language": 20,
    "semantic_fuzzy": 20
  },
